# EVPN-VXLAN Lab - Environment variables
# Copy this file to .env, fill in your values, then: source .env
# Do NOT commit the filled-in version.

# NetBox connection
NETBOX_URL=http://<your-netbox-host>:8000
NETBOX_TOKEN=<your-netbox-api-token>

# Containerlab server
CLAB_HOST=<containerlab-server-ip>
CLAB_USER=root
CLAB_SSH_KEY=<path-to-ssh-private-key>

# Management network
MGMT_SUBNET=<management-subnet-cidr>
MGMT_GATEWAY=<management-gateway-ip>

# Device management IPs (assigned to fxp0 as OOB)
MGMT_dc1_spine1=<ip/mask>
MGMT_dc1_spine2=<ip/mask>
MGMT_dc1_leaf1=<ip/mask>
MGMT_dc1_leaf2=<ip/mask>
